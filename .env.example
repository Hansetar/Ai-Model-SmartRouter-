# =====================================================================
# OpenClaw SmartRouter 环境变量
# =====================================================================
# 复制此文件为 .env 并填入真实值
# docker compose 会自动读取 .env 文件，无需在 compose 中重复配置
# =====================================================================

# ---- 服务配置 ----
# 容器内服务端口（默认 8000，一般不需要修改）
SMARTROUTER_PORT=8000
# 日志级别: debug / info / warning / error
SMARTROUTER_LOG_LEVEL=info

# ---- 认证配置 ----
# 管理面板密码（默认 admin，强烈建议修改）
SMARTROUTER_ADMIN_PASSWORD=admin
# JWT 签名密钥（留空则自动从 admin 密码派生，多实例部署时建议统一设置）
# SMARTROUTER_JWT_SECRET=your-random-secret
# /v1 接口 API Key 认证（留空不启用，设置后调用需携带 Authorization: Bearer <key>）
# SMARTROUTER_API_KEY=sk-your-router-key

# ---- 模型 API Key ----
# 命名规则：SMARTROUTER_API_KEY_<模型名大写，- 替换为 _，. 替换为 _>
# 填入对应模型的 API Key，会覆盖 config.yaml 中的值
# 未填写的模型将使用 config.yaml 中的值（通常为空）

# DeepSeek（用于 deepseek-chat）
SMARTROUTER_API_KEY_DEEPSEEK_CHAT=sk-your-deepseek-key

# 智谱（用于 glm-4-flash）
SMARTROUTER_API_KEY_GLM_4_FLASH=your-zhipu-key

# OpenAI（用于 gpt-4o-mini）
SMARTROUTER_API_KEY_GPT_4O_MINI=sk-your-openai-key

# SiliconFlow（用于 qwen2.5-7b-instruct 等免费模型）
SMARTROUTER_API_KEY_QWEN2_5_7B_INSTRUCT=sk-your-siliconflow-key

# 本地模型（用于 local-llama3，通常不需要）
# SMARTROUTER_API_KEY_LOCAL_LLAMA3=
