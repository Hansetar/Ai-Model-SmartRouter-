#!/usr/bin/env node
const fs = require('fs');
const path = require('path');
const os = require('os');

const SKILL_NAME = 'grill-me';

// Determine target directory
const platform = os.platform();
let targetDir;
if (platform === 'win32') {
  targetDir = path.join(process.env.APPDATA || path.join(os.homedir(), 'AppData', 'Roaming'), 'cognition', 'skills', SKILL_NAME);
} else {
  targetDir = path.join(os.homedir(), '.config', 'cognition', 'skills', SKILL_NAME);
}

// Ensure target directory exists
fs.mkdirSync(targetDir, { recursive: true });

// Recursively copy all files from skill/ directory
function copyRecursive(srcDir, destDir) {
  let count = 0;
  fs.mkdirSync(destDir, { recursive: true });
  const entries = fs.readdirSync(srcDir, { withFileTypes: true });
  for (const entry of entries) {
    const src = path.join(srcDir, entry.name);
    const dest = path.join(destDir, entry.name);
    if (entry.isDirectory()) {
      count += copyRecursive(src, dest);
    } else {
      fs.copyFileSync(src, dest);
      count++;
    }
  }
  return count;
}

const skillDir = path.join(__dirname, '..', 'skill');
const copied = copyRecursive(skillDir, targetDir);

console.log('');
console.log('  \x1b[32m\u2713\x1b[0m Skill "' + SKILL_NAME + '" installed! (' + copied + ' file' + (copied !== 1 ? 's' : '') + ')');
console.log('');
console.log('  Location: ' + targetDir);
console.log('');
console.log('  Usage in Devin for Terminal:');
console.log('    /' + SKILL_NAME);
console.log('');
